# OpenAI API Key para ChatGPT
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend API Key para envio de emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Microsoft Clarity
NEXT_PUBLIC_CLARITY_ID=XXXXXXXXXX

# Facebook Pixel (Opcional)
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXX

# Supabase – Sistema de Vistorias
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Cloudinary – Upload de fotos de vistoria
# Crie um Upload Preset "vistoria_maginf" em Cloudinary > Settings > Upload > Upload Presets (Unsigned)
CLOUDINARY_UPLOAD_PRESET=vistoria_maginf

# Senha de acesso ao sistema de vistorias (técnicos em campo)
NEXT_PUBLIC_VISTORIA_SENHA=marriott2026

# Senha de acesso ao portal do cliente (Marriott)
NEXT_PUBLIC_CLIENTE_SENHA=marriott@cliente2026
