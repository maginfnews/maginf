# Nenhuma variavel abaixo e obrigatoria para rodar o projeto.
# Quando nao houver configuracao manual, o frontend tenta usar /api/contact no mesmo dominio.
# Configure apenas se quiser apontar o diagnostico para um webhook externo.

# Endpoint HTTP que recebe o payload JSON do diagnostico.
# Exemplo: https://hooks.seusistema.com/maginf/lead
VITE_LEAD_WEBHOOK_URL=

# Token opcional enviado no header Authorization: Bearer <token>.
VITE_LEAD_WEBHOOK_TOKEN=
