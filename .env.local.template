# Template local para configurar o envio de emails com Resend.
# Copie este arquivo para ".env.local" e preencha com os dados reais.

# Chave da API do Resend com permissao para o dominio verificado.
RESEND_API_KEY=re_sua_chave_aqui

# Dominio/remetente que precisa estar verificado no Resend.
RESEND_FROM_EMAIL=contato@notificacao.maginf.com.br
RESEND_FROM_NAME=Site MAGINF

# Destinatario que vai receber os contatos e diagnosticos do site.
RESEND_CONTACT_TO=maicon@magpass.com.br

# Exemplo opcional de URL publica do site.
# NEXT_PUBLIC_SITE_URL=https://maginf.com.br
